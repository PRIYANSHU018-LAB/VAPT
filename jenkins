pipeline {
    agent any

    stages {
        stage("Clone Code") {
            steps {
                git branch: "main", url: "https://github.com/PRIYANSHU018-LAB/VAPT.git"
            }
        }

        stage("Build Docker Image") {
            steps {
                sh "docker build -t automated-vapt:latest ."
            }
        }

        stage("Run Container") {
            steps {
                sh "docker run -d --name vapt-app -p 5000:5000 automated-vapt:latest || true"
            }
        }
    }
}
